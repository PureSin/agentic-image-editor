# --- Google Gemini (default) ---
API_KEY=your-gemini-api-key
MODEL=gemini/gemini-3.1-flash-lite-preview
# API_BASE not needed for Gemini

# --- z.AI ---
# API_KEY=your-zai-api-key
# MODEL=openai/GLM-4.6V
# API_BASE=https://api.z.ai/api/paas/v4/

# Per-agent model overrides (fall back to MODEL if not set)
# EDITOR_MODEL=gemini/gemini-3.1-flash-lite-preview
# JUDGE_MODEL=gemini/gemini-3.1-flash-lite-preview

# Loop configuration (can also be passed as CLI flags)
MAX_ITERATIONS=3
